generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String              @id @default(cuid())
  name           String?
  email          String?             @unique
  emailVerified  DateTime?
  image          String?
  entraOid       String?             @unique
  entraGroups    String[]
  lastLoginAt    DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  accounts       Account[]
  sessions       Session[]
  tokens         PersonalToken[]
  connections    UserMcpConnection[]
  mcpPreferences UserMcpPreference[]
  toolExecutions McpToolExecution[]
  workspaces     Workspace[]         @relation("WorkspaceUsers")
  namespaces     McpNamespace[]      @relation("NamespaceUsers")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model McpServer {
  id                  String               @id @default(cuid())
  name                String
  description         String?
  transport           String
  command             String?
  args                String[]             @default([])
  url                 String?
  env                 Json                 @default("{}")
  headers             Json                 @default("{}")
  authType            String               @default("none")
  sharedSecret        String?
  oauthClientId       String?
  oauthClientSecret   String?
  oauthScopes         String?
  enabled             Boolean              @default(true)
  healthStatus        String               @default("unknown")
  lastHealthCheckAt   DateTime?
  lastLatencyMs       Int?
  consecutiveFailures Int                  @default(0)
  connectionTimeoutMs Int                  @default(10000)
  toolTimeoutMs       Int                  @default(30000)
  maxRetries          Int                  @default(1)
  failureThreshold    Int                  @default(3)
  circuitCooldownMs   Int                  @default(60000)
  maxConcurrentCalls  Int                  @default(5)
  rateLimitRequests   Int                  @default(60)
  rateLimitWindowMs   Int                  @default(60000)
  circuitState        String               @default("closed")
  circuitOpenedAt     DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  connections         UserMcpConnection[]
  userPreferences     UserMcpPreference[]
  policies            AccessPolicy[]
  registryTools       McpToolRegistry[]
  toolExecutions      McpToolExecution[]
  namespaceMembers    NamespaceMcpServer[]
}

model McpToolRegistry {
  id             String          @id @default(cuid())
  mcpServerId    String
  mcpServer      McpServer       @relation(fields: [mcpServerId], references: [id], onDelete: Cascade)
  name           String
  displayName    String?
  description    String?         @db.Text
  inputSchema    Json            @default("{}")
  annotations    Json            @default("{}")
  schemaHash     String
  enabled        Boolean         @default(true)
  permissionMode String          @default("allow")
  readOnly       Boolean         @default(false)
  destructive    Boolean         @default(false)
  discoveredAt   DateTime        @default(now())
  lastSeenAt     DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  namespaceTools NamespaceTool[]

  @@unique([mcpServerId, name])
  @@index([mcpServerId, enabled])
  @@index([lastSeenAt])
}

model McpToolExecution {
  id              String     @id @default(cuid())
  mcpServerId     String?
  mcpServer       McpServer? @relation(fields: [mcpServerId], references: [id], onDelete: SetNull)
  actorUserId     String?
  actorUser       User?      @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  personalTokenId String?
  serverName      String
  toolName        String
  source          String
  traceId         String?
  status          String
  latencyMs       Int
  attemptCount    Int        @default(1)
  arguments       Json       @default("{}")
  errorMessage    String?    @db.Text
  createdAt       DateTime   @default(now())

  @@index([mcpServerId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([personalTokenId, createdAt])
  @@index([source, createdAt])
  @@index([status, createdAt])
  @@index([traceId])
}

model Skill {
  id          String         @id @default(cuid())
  name        String
  description String?
  content     String         @db.Text
  enabled     Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  policies    AccessPolicy[]
  workspaces  Workspace[]
}

model LlmConfig {
  id             String      @id @default(cuid())
  displayName    String
  provider       String
  credentials    Json        @default("{}")
  allowedModels  String[]    @default([])
  enabled        Boolean     @default(true)
  isDefault      Boolean     @default(false)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  workspaces     Workspace[]
  inputTokens    Int         @default(0)
  outputTokens   Int         @default(0)
  totalTokens    Int         @default(0)
  lastTestAt     DateTime?
  lastTestStatus String      @default("unknown")
}

model EntraGroup {
  id           String         @id @default(cuid())
  entraGroupId String         @unique
  displayName  String
  memberCount  Int            @default(0)
  isActive     Boolean        @default(true)
  lastSyncedAt DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  policy       AccessPolicy?
  workspaces   Workspace[]
  namespaces   McpNamespace[]
}

model AccessPolicy {
  id            String      @id @default(cuid())
  groupId       String      @unique
  group         EntraGroup  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  allowedModels String[]    @default([])
  mcpServers    McpServer[]
  skills        Skill[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model PersonalToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  tokenHash  String    @unique
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
}

model UserMcpConnection {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  mcpServerId  String
  mcpServer    McpServer @relation(fields: [mcpServerId], references: [id], onDelete: Cascade)
  accessToken  String    @db.Text
  refreshToken String?   @db.Text
  tokenType    String    @default("Bearer")
  expiresAt    DateTime?
  scope        String?
  status       String    @default("connected")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([userId, mcpServerId])
}

model UserMcpPreference {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  mcpServerId String
  mcpServer   McpServer @relation(fields: [mcpServerId], references: [id], onDelete: Cascade)
  enabled     Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([userId, mcpServerId])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  userEmail  String?
  action     String
  resource   String
  resourceId String?
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now())

  @@index([action, createdAt])
  @@index([userId, createdAt])
  @@index([resource, createdAt])
  @@index([createdAt])
}

model Workspace {
  id                   String        @id @default(cuid())
  slug                 String        @unique
  name                 String        @unique
  description          String?
  systemPrompt         String?       @db.Text
  model                String?
  maxSteps             Int           @default(6)
  approvalMode         String        @default("risk_based")
  conversationStarters String[]      @default([])
  enabled              Boolean       @default(true)
  isDefault            Boolean       @default(false)
  llmConfigId          String?
  llmConfig            LlmConfig?    @relation(fields: [llmConfigId], references: [id], onDelete: SetNull)
  namespaceId          String?
  namespace            McpNamespace? @relation(fields: [namespaceId], references: [id], onDelete: SetNull)
  skills               Skill[]
  groups               EntraGroup[]
  users                User[]        @relation("WorkspaceUsers")
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@index([enabled, isDefault])
  @@index([llmConfigId])
  @@index([namespaceId])
}

model McpNamespace {
  id          String               @id @default(cuid())
  alias       String               @unique @map("slug")
  name        String               @unique
  description String?
  enabled     Boolean              @default(true)
  published   Boolean              @default(false)
  groups      EntraGroup[]
  users       User[]               @relation("NamespaceUsers")
  servers     NamespaceMcpServer[]
  tools       NamespaceTool[]
  workspaces  Workspace[]
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([enabled, published])
}

model NamespaceMcpServer {
  id           String       @id @default(cuid())
  namespaceId  String
  namespace    McpNamespace @relation(fields: [namespaceId], references: [id], onDelete: Cascade)
  mcpServerId  String
  mcpServer    McpServer    @relation(fields: [mcpServerId], references: [id], onDelete: Cascade)
  alias        String?
  enabled      Boolean      @default(true)
  displayOrder Int          @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([namespaceId, mcpServerId])
  @@index([mcpServerId])
  @@index([namespaceId, enabled, displayOrder])
}

model NamespaceTool {
  id             String          @id @default(cuid())
  namespaceId    String
  namespace      McpNamespace    @relation(fields: [namespaceId], references: [id], onDelete: Cascade)
  registryToolId String
  registryTool   McpToolRegistry @relation(fields: [registryToolId], references: [id], onDelete: Cascade)
  alias          String
  displayName    String?
  description    String?         @db.Text
  enabled        Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([namespaceId, registryToolId])
  @@unique([namespaceId, alias])
  @@index([registryToolId])
  @@index([namespaceId, enabled])
}
