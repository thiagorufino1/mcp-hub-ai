{
  "name": "@thiagorufino/mcp-hub",
  "version": "1.0.9",
  "private": false,
  "description": "MCP Hub is a local web UI for testing LLMs and MCP servers. Connect providers, inspect tool calls, and run multi-turn chats in one place.",
  "license": "Apache-2.0",
  "author": "Thiago Rufino",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thiagorufino1/mcp-hub.git"
  },
  "homepage": "https://github.com/thiagorufino1/mcp-hub#readme",
  "bugs": {
    "url": "https://github.com/thiagorufino1/mcp-hub/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "mcp-hub": "bin/mcp-portal.mjs"
  },
  "files": [
    ".next/standalone",
    "bin"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build && node scripts/fix-next-types.mjs",
    "start": "next start",
    "lint": "eslint . --ignore-pattern .next --ignore-pattern .next-package --ignore-pattern .npm-package",
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/*.test.mjs",
    "test:smoke": "node scripts/smoke-test-package.mjs",
    "build:package": "node scripts/build-package.mjs",
    "prepare:publish-dir": "npm run build:package && node scripts/prepare-publish-dir.mjs",
    "pack:check": "node scripts/check-pack.mjs",
    "publish:package-dir": "npm run prepare:publish-dir"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "mcp-client",
    "mcp-hub",
    "model-context-protocol",
    "ai",
    "llm",
    "llm-ui",
    "chat-ui",
    "ai-tools",
    "tool-calling",
    "tool-inspection",
    "multi-turn-chat",
    "prompt-testing"
  ],
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^4.0.96",
    "@ai-sdk/anthropic": "^3.0.71",
    "@ai-sdk/azure": "^3.0.54",
    "@ai-sdk/deepseek": "^2.0.29",
    "@ai-sdk/google": "^3.0.64",
    "@ai-sdk/groq": "^3.0.35",
    "@ai-sdk/mistral": "^3.0.30",
    "@ai-sdk/openai": "^3.0.53",
    "@ai-sdk/xai": "^3.0.83",
    "@auth/prisma-adapter": "^2.11.2",
    "@lobehub/icons": "^5.5.4",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@prisma/client": "^6.19.3",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tabler/icons-react": "^3.41.1",
    "@thiagorufino/mcp-hub": "^1.0.9",
    "ai": "^6.0.168",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "next": "^16.2.1",
    "next-auth": "^5.0.0-beta.31",
    "next-themes": "^0.4.6",
    "open": "^11.0.0",
    "prisma": "^6.19.3",
    "react": "^19.2.4",
    "react-circle-flags": "^0.0.29",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "rehype-highlight": "^7.0.2",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "overrides": {
    "postcss": ">=8.5.10"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3"
  }
}
