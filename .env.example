# Database (used by Prisma)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mcphub"

# NextAuth
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-in-production"
NEXTAUTH_URL="http://localhost:3000"

# Azure AD / Entra ID
# Create app registration at https://portal.azure.com
# Required API permissions: openid, profile, email, User.Read
# Optional (for groups): GroupMember.Read.All or configure groups claim in token
AZURE_AD_CLIENT_ID="your-client-id"
AZURE_AD_CLIENT_SECRET="your-client-secret"
AZURE_AD_TENANT_ID="your-tenant-id"

# Entra group object ID that grants admin access to /admin routes
ADMIN_GROUP_ID="your-admin-group-object-id"
